<mujoco model="template model">
    <compiler angle="degree" coordinate="local" inertiafromgeom="false" autolimits="true" texturedir="PNG"/>

    <option timestep="0.001" gravity="0 0 -9.81" integrator="Euler" o_solref="0.005 0.2" o_solimp="0.95 0.98 0.01 0.5 2" cone="elliptic" jacobian="auto" solver="Newton" tolerance="1e-10" impratio="1.0"/>
	<!-- <option timestep="0.001" gravity="0 0 -9.81" tolerance="1e-08" cone="elliptic" jacobian="dense" solver="Newton" 
					integrator="implicitfast" iterations="30"/> -->
    <option>
        <flag gravity="enable" override="enable"/>
    </option>

    <visual>
        <global fovy="45" linewidth="1" glow="0.3"/>
        <quality shadowsize="4096" numslices="48"/>
        <map stiffness="50" stiffnessrot="100"/>
        <scale forcewidth="0.05" contactwidth="0.15" contactheight="0.1" connect="0.1" com="0.2" jointlength="0.25" jointwidth="0.05" 
                    actuatorlength="0.5" actuatorwidth="0.3" framelength="1" framewidth="0.03"/>
        <rgba haze="0.6 0.8 0.9 1" force="1 0 0 0.5" com="0 0 1 1"/>
    </visual>

    <default>
        <geom contype="1" conaffinity="1" condim="3" material="MatGnd"/>
        <joint limited="false" damping="0.1" armature="0.1" stiffness="0" frictionloss="0.1"/>
        <motor gear="1 0 0 0 0 0" ctrllimited="false" ctrlrange="-100 100"/>
    </default>


    <worldbody>

        <body name="Pelvis" pos="0 0 0.775">
            <inertial pos="2e-05 -2.1e-20 0.15" quat="1 0 -0.00026 0" mass="12" diaginertia="0.18 0.15 0.071"/>
            <joint name="floating_body" pos="0 0 0" type="free" armature="0"/>

            <geom type="box" pos="0 0 0" euler="0 0 0" size="0.06 0.07 0.03" rgba="0.5 0.5 0.5 1"/>
            <geom type="box" pos="0 0 0.18" euler="0 0 0" size="0.07 0.12 0.15" rgba="0.6 0.6 0.6 1 "/>

            <geom type="box" pos="-0.065 0 -0.05" euler="0 0 0" size="0.005 0.07 0.05" rgba="0.5 0.5 0.5 1"/>
            <geom type="cylinder" pos="-0.065 -0.041 -0.1" euler="0 90 0" size="0.041 0.005" rgba="0.5 0.5 0.5 1"/>
            <geom type="cylinder" pos="-0.065  0.041 -0.1" euler="0 90 0" size="0.041 0.005" rgba="0.5 0.5 0.5 1"/>

            <geom type="box" pos="0.065 0 -0.05" euler="0 0 0" size="0.005 0.07 0.05" rgba="0.5 0.5 0.5 1"/>
            <!-- <geom type="box" pos="0.055 -0.041 -0.065" euler="0 0 0" size="0.005 0.025 0.035" rgba="0.5 0.5 0.5 1"/> -->
            <geom type="cylinder" pos="0.056 -0.041 -0.1" euler="0 90 0" size="0.041 0.006" rgba="0.5 0.5 0.5 1"/>
            <!-- <geom type="box" pos="0.055  0.041 -0.065" euler="0 0 0" size="0.005 0.025 0.035" rgba="0.5 0.5 0.5 1"/> -->
            <geom type="cylinder" pos="0.056 0.041 -0.1" euler="0 90 0" size="0.041 0.006" rgba="0.5 0.5 0.5 1"/>

            <!-- Roll Actuator Geometry -->
            <geom type="cylinder" pos="-0.1  0.041 -0.1" euler="0 90 0" size="0.041 0.03" rgba="1.0 0.3 0.5 1"/>
            <geom type="cylinder" pos="-0.1 -0.041 -0.1" euler="0 90 0" size="0.041 0.03" rgba="1.0 0.3 0.5 1"/>

            <body name="left_hip_roll" pos="0 0.041 -0.1">
                <!-- <inertial pos="0 0 0" mass="0.58"  diaginertia="0.00072 0.00066 0.00048"/> -->
                <inertial pos="0 0.017 0" quat="0.5 0.5 -0.5 0.5" mass="0.58" diaginertia="0.00072 0.00066 0.00048"/>
                <joint name="left_hip_roll" type="hinge" axis="1 0 0" armature="0.1" limited="true" range="-90 90" springref="0" springdamper="0.05 1"/>
                <geom type="cylinder" pos="0.0 0.02 0.0" size=".04 0.05" rgba="1.0 0.3 0.5 1" euler="90 0 0" />
                <geom type="cylinder" pos="0.0 -0.0 0.0" euler="0 90 0" size="0.015 0.054" rgba="0.7 0.7 0.7 1"/>

                <body name="left_hip_pitch" pos="0 0.1 0">
                    <!-- <inertial pos="0 0 -0.15" mass="5.5"  diaginertia="0.16 0.16 0.0081"/> -->
                    <inertial pos="0 0 -0.18" quat="0.71 0 0 0.71" mass="5.5" diaginertia="0.16 0.16 0.0081"/>
                    <joint name="left_hip_pitch" type="hinge" axis="0 -1 0" limited="true" range="-60 60" pos="0 0 0.0" />
                    <geom type="cylinder" size=".07 0.05" rgba="0.6 0.6 0.6 1" euler="90 0 0" />
                    <geom type="cylinder" pos="0. 0. -0.25" size=".05 0.25" rgba="0.6 0.6 0.6 1" euler="0 0 90" />

                    <body name="left_foot" pos="0 0 -0.5" euler="180 0 0">
                        <!-- <inertial pos="0 0 0" mass="0.84"  diaginertia="0.0053 0.0053 0.00059"/> -->
                        <inertial pos="0 0 0.078" quat="1 0 0 0" mass="0.84" diaginertia="0.0053 0.0053 0.00059"/>
                        <joint name="left_knee" type="slide" limited="true" range="-0.125 0.125" springref="0" springdamper="5 1" pos="0 0 0"  axis="0 0 1"/>
                        <geom type="cylinder" pos="0 0 0" size=".02 0.125" rgba="0 0 1 1" />
                        <geom name="lfoot" type="sphere" pos="0 0 0.125" size="0.05" rgba="1 1 .0 1" />
                        <site name="left_ee" pos="0 0 0.125" type="sphere" euler="180 0 0" size="0.02" rgba="0.1 0.5 2.2 1" />
                    </body>
                </body>
            </body>

            <body name="right_hip_roll" pos="0 -0.041 -0.1">
                <!-- <inertial pos="0 0 0" mass="0.58"  diaginertia="0.00072 0.00066 0.00048"/> -->
                <inertial pos="0 -0.017 0" quat="0.5 0.5 -0.5 0.5" mass="0.58" diaginertia="0.00072 0.00066 0.00048"/>
                <joint name="right_hip_roll" type="hinge" axis="1 0 0" armature="0.1" limited="true" range="-90 90" springref="0" springdamper="0.05 1"/>
                <geom type="cylinder" pos="0.0 -0.02 0.0" size=".04 0.05" rgba="1.0 0.3 0.5 1" euler="90 0 0" />
                <geom type="cylinder" pos="0.0 -0.0 0.0" euler="0 90 0" size="0.015 0.054" rgba="0.7 0.7 0.7 1"/>

                <body name="right_hip_pitch" pos="0 -0.1 0.0">
                    <!-- <inertial pos="0 0 -0.15" mass="5.5"  diaginertia="0.16 0.16 0.0081"/> -->
                    <inertial pos="0 0 -0.18" quat="0.71 0 0 0.71" mass="5.5" diaginertia="0.16 0.16 0.0081"/>
                    <joint name="right_hip_pitch" type="hinge" axis="0 -1 0" limited="true" range="-60 60" pos="0 0 0.0"  />
                    <geom type="cylinder" size=".07 0.05" rgba="0.6 0.6 0.6 1" euler="90 0 0" />
                    <geom type="cylinder" pos="0. 0. -0.25" size=".05 0.25" rgba="0.6 0.6 0.6 1" euler="0 0 90" />

                    <body name="right_foot" pos="0 0 -0.5" euler="180 0 0">
                        <!-- <inertial pos="0 0 0" mass="0.84"  diaginertia="0.0053 0.0053 0.00059"/> -->
                        <inertial pos="0 0 0.078" quat="1 0 0 0" mass="0.84" diaginertia="0.0053 0.0053 0.00059"/>
                        <joint name="right_knee" type="slide" limited="true" range="-0.125 0.125" springref="0" springdamper="5 1" pos="0 0 0" axis="0 0 1"/>
                        <geom type="cylinder" pos="0 0 0" size=".02 0.125" rgba="0 0 1 1"/>
                        <geom name="rfoot" type="sphere" pos="0 0 0.125" size="0.05" rgba="1 1 .0 1" />
                        <site name="right_ee" pos="0 0 0.125" type="sphere" euler="180 0 0" size="0.02" rgba="0.1 0.5 2.2 1" />
                    </body>
                </body>
            </body>
        </body>

    </worldbody>

    <!-- <equality> -->
        <!-- <connect body1='Pelvis' body2='world' anchor='0 0 1.3'/> -->
        <!-- <weld body1='Pelvis' relpose="0 0 0 0 0 0 0"/> -->
    <!-- </equality> -->

    <actuator>
        <motor name="left_hip_roll" ctrllimited="false" gear="1 0 0 0 0 0" joint="left_hip_roll" />
        <motor name="left_hip_pitch" ctrllimited="false" gear="1 0 0 0 0 0" joint="left_hip_pitch" />
        <motor name="left_knee" ctrllimited="false" gear="1 0 0 0 0 0" joint="left_knee" />
        <motor name="right_hip_roll" ctrllimited="false" gear="1 0 0 0 0 0" joint="right_hip_roll" />
        <motor name="right_hip_pitch" ctrllimited="false" gear="1 0 0 0 0 0" joint="right_hip_pitch" />
        <motor name="right_knee" ctrllimited="false" gear="1 0 0 0 0 0" joint="right_knee" />
    </actuator>

    <sensor>
        <!-- <framepos objtype="site" objname="com" /> -->
        <!-- <framepos objtype="site" objname="prev_footplacement" /> -->
        <!-- <framepos objtype="site" objname="footplacement" /> -->
        <!-- <framepos objtype="site" objname="dcm_offset" /> -->
        <framepos objtype="site" objname="left_ee" />
        <framepos objtype="site" objname="right_ee" />
    </sensor>

</mujoco>